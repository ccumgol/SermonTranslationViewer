# ─────────────────────────────────────────────────────────────
# 이 파일을 복사해서 `.env` 로 만든 뒤 실제 값을 채우세요.
#   cp .env.example .env
# `.env` 는 .gitignore 에 의해 git 에 올라가지 않습니다. (민감 정보 보호)
# ─────────────────────────────────────────────────────────────

# Google AI Studio 에서 발급받은 Gemini API 키
# https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_발급받은_키를_붙여넣으세요

# 사용할 모델 (공식 문서 기준 실시간 번역 전용 모델)
GEMINI_MODEL=gemini-3.5-live-translate-preview

# 번역 대상 언어 = 자막으로 출력할 언어
# ⚠️ 짧은 코드를 쓰세요(en O / en-US X). 검증된 코드:
#    en 영어  ja 일본어  zh 또는 zh-CN 중국어  es 스페인어
#    vi 베트남어  fr 프랑스어  ru 러시아어  (모델은 70여개 지원)
TARGET_LANGUAGE=en

# 원본 언어 — 모델이 자동 감지하므로 보통 그대로 두면 됨 (참고용)
SOURCE_LANGUAGE=ko

# 자막 웹서버 포트
WS_HOST=0.0.0.0
WS_PORT=8000

# 오디오 입력 장치: 숫자=인덱스, 문자열=장치이름 (비우면 시스템 기본 입력)
# `python server/audio_input.py --list` 로 확인 후 입력
# 예) 2 = Vocaster Two USB (믹서),  비움 = 맥북 내장 마이크
AUDIO_INPUT_DEVICE=
