# ─────────────────────────────────────────────────────────────
# 이 파일을 복사해서 `.env` 로 만든 뒤 실제 값을 채우세요.
#   cp .env.example .env
# `.env` 는 .gitignore 에 의해 git 에 올라가지 않습니다. (민감 정보 보호)
# ─────────────────────────────────────────────────────────────

# Google AI Studio 에서 발급받은 Gemini API 키
# https://aistudio.google.com/apikey
GEMINI_API_KEY=여기에_발급받은_키를_붙여넣으세요

# 사용할 모델 (공식 문서 기준 실시간 번역 전용 모델)
GEMINI_MODEL=gemini-3.5-live-translate-preview

# 번역 백엔드: gemini(온라인, API 키 필요) 또는 local(오프라인, 비용 0)
#   local 모드는 Ollama + translategemma:12b + mlx-qwen3-asr 가 설치돼 있어야 함
#   (requirements-offline.txt 참고). Apple Silicon Mac 필요.
BACKEND=gemini

# ── 오프라인(local) 모드 튜닝 (선택) ──────────────────────────
# STT 모델: 0.6B(빠름·권장) / 1.7B(약간 정확하나 느림)
# STT_MODEL=Qwen/Qwen3-ASR-0.6B
# MT 모델: translategemma:12b(정확·권장) / translategemma:4b(빠름)
# MT_MODEL=translategemma:12b
# VAD: 침묵 음량 임계값(말해도 자막 안 뜨면 낮추고, 잡음 반응하면 높임)
# STT_SILENCE_RMS=0.015
# STT_MIN_SILENCE_SEC=0.7        # 발화를 끊는 침묵 길이(초)
# STT_MAX_SEGMENT_SEC=12.0       # 쉼 없이 길게 말할 때 강제 분할 상한(초)
#
# 용어집(고유명사 인식·번역 보정)은 파일로 지정:
#   cp data/glossary/glossary.example.txt data/glossary/glossary.txt 후 편집

# 번역 대상 언어 = 자막으로 출력할 언어
# ⚠️ 짧은 코드를 쓰세요(en O / en-US X). 검증된 코드:
#    en 영어  ja 일본어  zh 또는 zh-CN 중국어  es 스페인어
#    vi 베트남어  fr 프랑스어  ru 러시아어  (모델은 70여개 지원)
TARGET_LANGUAGE=en

# 원본 언어 — 모델이 자동 감지하므로 보통 그대로 두면 됨 (참고용)
SOURCE_LANGUAGE=ko

# 자막 웹서버 호스트/포트
#   0.0.0.0 = 같은 LAN(폰/다른 PC)에서 접속 가능 (셀폰 자막 보기 O, 단 보안 주의)
#   127.0.0.1 = 이 컴퓨터에서만 접속 (가장 안전)
WS_HOST=0.0.0.0
WS_PORT=8000

# 운영자 보호 토큰(선택, 권장). 설정 시 /operator 명령에 토큰 필요.
#   접속: http://<주소>:8000/operator?token=여기에토큰
#   비워두고 WS_HOST=0.0.0.0 이면 같은 LAN 누구나 설정 변경 가능(경고 출력)
OPERATOR_TOKEN=

# 전사/번역을 파일로 기록(사후 검토용). 1/true 면 data/logs/ 에 JSONL 저장.
# LOG_TRANSCRIPTS=1
# 비용 표시/경고(온라인): 분당 단가(USD), 무발화 경고 시작 분
# COST_PER_MIN=0.037
# IDLE_WARN_MIN=5

# 오디오 입력 장치: 숫자=인덱스, 문자열=장치이름 (비우면 시스템 기본 입력)
# `python server/audio_input.py --list` 로 확인 후 입력
# 예) 2 = Vocaster Two USB (믹서),  비움 = 맥북 내장 마이크
AUDIO_INPUT_DEVICE=
